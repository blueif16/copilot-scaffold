# Production Environment Configuration - EXAMPLE
# Copy this file to .env.production and fill in your actual values
# Server: 66.42.117.148

# ============================================================================
# API Keys (REQUIRED)
# ============================================================================

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
# Used by: Backend service for AI/LLM functionality
GOOGLE_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE

# LangSmith API Key (Optional - for debugging/tracing LangGraph agents)
# Get from: https://smith.langchain.com/
# Used by: Backend service for agent debugging and observability
LANGSMITH_API_KEY=

# ============================================================================
# Backend Configuration
# ============================================================================

# Backend API URLs - Production server
# Used by: Frontend to connect to FastAPI backend
BACKEND_URL=http://66.42.117.148:8124
NEXT_PUBLIC_BACKEND_URL=http://66.42.117.148:8124

# ============================================================================
# Supabase Configuration
# ============================================================================

# Supabase API URLs - Production server (Kong API Gateway on port 8000)
# Used by: Frontend and backend to connect to Supabase services
NEXT_PUBLIC_SUPABASE_URL=http://66.42.117.148:8000
SUPABASE_URL=http://66.42.117.148:8000
SUPABASE_PUBLIC_URL=http://66.42.117.148:8000

# JWT Secret - CRITICAL: Must be at least 32 characters
# Generate with: openssl rand -base64 32
# Used by: All Supabase services for JWT token signing/verification
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Supabase JWT Keys - CRITICAL: Generate using your JWT_SECRET
# Generate with: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# Or use the Supabase CLI: supabase gen keys --project-ref YOUR_PROJECT
#
# Alternative method using Docker:
# docker run --rm supabase/gotrue:v2.132.3 gotrue generate keys --secret YOUR_JWT_SECRET
#
# anon key: Used for client-side requests (public, read-only access)
# service_role key: Used for server-side requests (full admin access)
SUPABASE_ANON_KEY=CHANGE_ME_GENERATE_ANON_KEY_WITH_JWT_SECRET
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME_GENERATE_ANON_KEY_WITH_JWT_SECRET
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_GENERATE_SERVICE_ROLE_KEY_WITH_JWT_SECRET

# ============================================================================
# PostgreSQL Database
# ============================================================================

# Database Password - CRITICAL: Use a strong, unique password
# Generate with: openssl rand -base64 32
# Used by: All services connecting to PostgreSQL (Supabase, Letta, Backend)
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD_WITH_OPENSSL

# Database Connection URL for LangGraph Checkpointing
# Used by: Backend service for storing agent conversation state
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:CHANGE_ME_SAME_PASSWORD_AS_ABOVE@66.42.117.148:5432/postgres

# ============================================================================
# Supabase Realtime Configuration
# ============================================================================

# Realtime Database Encryption Key - CRITICAL: Generate new key for production
# Generate with: openssl rand -base64 32
# Used by: Supabase Realtime service for encrypting database connections
DB_ENC_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Realtime Secret Key Base - CRITICAL: Generate new key for production
# Generate with: openssl rand -base64 64
# Used by: Supabase Realtime service for session encryption
SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# ============================================================================
# Letta Configuration
# ============================================================================

# Letta Memory System API URL
# Used by: Backend service to connect to Letta for student memory management
LETTA_BASE_URL=http://66.42.117.148:8283

# ============================================================================
# Site Configuration
# ============================================================================

# Frontend URL - Used for CORS, redirects, and email links
# Used by: Supabase Auth for redirect URLs after login/signup
SITE_URL=http://66.42.117.148:3082

# ============================================================================
# Auth Configuration
# ============================================================================

# Disable public signups (set to true for invite-only mode)
# Used by: Supabase Auth (GoTrue)
DISABLE_SIGNUP=false

# Email signup settings
# Used by: Supabase Auth for email/password authentication
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# JWT token expiry in seconds (default: 3600 = 1 hour)
# Used by: Supabase Auth for JWT token lifetime
JWT_EXPIRY=3600

# Additional allowed redirect URLs after authentication (comma-separated)
# Example: http://app.example.com,https://app.example.com
# Used by: Supabase Auth for validating redirect URLs
ADDITIONAL_REDIRECT_URLS=

# ============================================================================
# Email/SMTP Configuration (Optional - for production email notifications)
# ============================================================================

# SMTP settings for sending authentication emails
# Get from: Your email provider (Gmail, SendGrid, AWS SES, etc.)
# Used by: Supabase Auth for sending verification/recovery emails
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=

# Email template URL paths (usually don't need to change these)
# Used by: Supabase Auth for email link generation
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# ============================================================================
# Image Proxy Configuration
# ============================================================================

# Enable WebP detection for automatic image format optimization
# Used by: imgproxy service for serving optimized images
IMGPROXY_ENABLE_WEBP_DETECTION=true

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================
#
# Before deploying to production:
#
# [ ] Generate new JWT_SECRET (openssl rand -base64 32)
# [ ] Generate new POSTGRES_PASSWORD (openssl rand -base64 32)
# [ ] Generate new DB_ENC_KEY (openssl rand -base64 32)
# [ ] Generate new SECRET_KEY_BASE (openssl rand -base64 64)
# [ ] Generate Supabase keys using JWT_SECRET
# [ ] Add your Google Gemini API key
# [ ] Update DATABASE_URL with the same POSTGRES_PASSWORD
# [ ] Configure SMTP settings if using email auth
# [ ] Add .env.production to .gitignore
# [ ] Never commit .env.production to version control
# [ ] Restrict PostgreSQL port 5432 access with firewall rules
# [ ] Set up SSL/TLS termination with reverse proxy (Nginx/Traefik)
# [ ] Configure automated database backups
# [ ] Set up monitoring and alerting
#
# ============================================================================
