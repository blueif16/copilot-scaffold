# Required environment variables — copy to .env and fill in values

# Google Gemini — powers both agents
# Observation agent: gemini-2.5-flash (AI reasoning for escalated reactions)
# Chat agent: gemini-2.5-flash-lite (fast, cheap conversational responses for kids)
# GOOGLE_API_KEY=

# LangSmith — LangGraph tracing and debugging (optional, but recommended)
# LANGSMITH_API_KEY=

# Backend URL — Frontend uses this to connect to the backend API
# For local dev: http://localhost:8123
# For Docker: http://backend:8123 (set in docker-compose.yml)
# BACKEND_URL=http://localhost:8123

# ============================================================================
# Supabase Configuration — Choose Cloud OR Self-Hosted
# ============================================================================

# Option 1: Supabase Cloud (Recommended for production)
# Sign up at https://supabase.com and create a project
# Get these values from Project Settings > API
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Option 2: Self-Hosted Supabase (Docker Compose)
# Use this for local development or self-hosted deployments
# When USE_SELFHOSTED_SUPABASE=true, the app connects to local Supabase services
USE_SELFHOSTED_SUPABASE=false

# Self-Hosted Supabase URLs (used when USE_SELFHOSTED_SUPABASE=true)
# For Docker: use service names (kong:8000)
# For local dev: use localhost
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

# Self-Hosted Supabase Keys
# IMPORTANT: Generate your own secure keys for production
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# ANON_KEY: Safe for client-side use (frontend), respects RLS policies
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# SERVICE_ROLE_KEY: NEVER expose to client/browser - bypasses RLS, server-only
# Store in .env (never commit), use only in backend code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# PostgreSQL Password (self-hosted only)
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password

# Auth Configuration (self-hosted only)
SITE_URL=http://localhost:3082
ADDITIONAL_REDIRECT_URLS=
DISABLE_SIGNUP=false
JWT_EXPIRY=3600
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# SMTP Configuration (self-hosted only, optional)
# Required for email confirmations and password resets
# Leave empty to use Supabase's Inbucket (local testing only)
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=

# Image Processing (self-hosted only)
IMGPROXY_ENABLE_WEBP_DETECTION=true

# ============================================================================
# Letta Configuration — Student Memory System
# ============================================================================

# Letta Base URL
# For local dev: http://localhost:8283
# For Docker: http://letta:8283 (set in docker-compose.yml)
LETTA_BASE_URL=http://localhost:8283

# ============================================================================
# LangGraph Checkpointing — PostgreSQL Connection
# ============================================================================

# PostgreSQL Connection String for LangGraph Checkpointing
# Used by course builder agent to persist conversation state
# For Docker: use service name (supabase-db:5432)
# For local dev: use localhost or remote IP
DATABASE_URL=postgresql://postgres:your-super-secret-and-long-postgres-password@supabase-db:5432/postgres
