# OpenAI API Key (required for LangGraph agent)
OPENAI_API_KEY=sk-...

# LangSmith (optional - for agent tracing)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=copilot-scaffold

# Backend URL
LANGGRAPH_DEPLOYMENT_URL=http://localhost:8123

# Next.js
NEXT_PUBLIC_COPILOT_RUNTIME_URL=/api/copilotkit
